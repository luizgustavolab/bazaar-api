# --- DATABASE (Prisma/SQLite) ---
# Em produção (PostgreSQL/MySQL), a URL mudará. Para local, use o caminho do arquivo.
DATABASE_URL="file:./dev.db"

# --- REDIS (BullMQ) ---
# Configurações para a fila de processamento. 
# Se usar Docker local, o host geralmente é 127.0.0.1.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD= (opcional, dependendo do seu setup)

# --- API CONFIG ---
# Porta onde o servidor Fastify irá rodar
PORT=3333
NODE_ENV=development

# --- SCRAPER CONFIG (Opcional) ---
# Caso decida usar ScraperAPI ou outra ferramenta de proxy no futuro
# SCRAPER_API_KEY=sua_chave_aqui
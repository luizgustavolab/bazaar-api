{
  "name": "bazaar-api-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "seed": "ts-node prisma/seed.ts",
    "generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "dev": "npm run generate && concurrently -p \"name\" -n \"API,WORKER,CRAWLER\" -c \"cyan,green,magenta\" \"npm:dev:api\" \"npm:dev:worker\" \"npm:dev:crawler\"",
    "dev:api": "cd apps/api && ts-node-dev --respawn --transpile-only --clear src/server.ts",
    "dev:worker": "cd apps/worker && ts-node-dev --respawn --transpile-only --clear src/index.ts",
    "dev:crawler": "cd apps/crawler && ts-node-dev --respawn --transpile-only --clear src/index.ts",
    "build": "npm run generate && tsc -b",
    "lint": "eslint \"apps/**/*.{ts,js}\"",
    "lint:fix": "eslint \"apps/**/*.{ts,js}\" --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@fastify/cors": "^8.5.0",
    "@prisma/client": "^5.6.0",
    "axios": "^1.13.6",
    "bullmq": "^5.70.1",
    "cheerio": "^1.2.0",
    "fastify": "^4.28.0",
    "ioredis": "^5.3.0",
    "prisma": "^5.6.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sqlite3": "^3.1.11",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.57.1",
    "prettier": "^3.2.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.2.2"
  }
}